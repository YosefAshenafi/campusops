# CampusOps Environment Configuration
# Copy to .env and update values

# Database (defaults match docker-compose.yml; changing these later does not update an existing volume)
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=campusops
DB_USERNAME=campusops
DB_PASSWORD=campusops_secret
DB_ROOT_PASSWORD=root_secret

# Application
APP_KEY=generate_a_random_key_here
APP_DEBUG=false
